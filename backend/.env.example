# === RentShield Backend Environment Variables ===

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
ALLOWED_ORIGINS=*

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# RapidAPI (shared key for Zillow + Realtor.com wrappers)
RAPIDAPI_KEY=your-rapidapi-key-here

# Zillow API via RapidAPI
ZILLOW_API_HOST=zillow-com1.p.rapidapi.com
ZILLOW_API_BASE_URL=https://zillow-com1.p.rapidapi.com

# Realtor.com API via RapidAPI
REALTOR_API_HOST=realtor16.p.rapidapi.com
REALTOR_API_BASE_URL=https://realtor16.p.rapidapi.com

# Rentcast API (direct, not via RapidAPI)
RENTCAST_API_KEY=your-rentcast-api-key-here
RENTCAST_API_BASE_URL=https://api.rentcast.io/v1

# Cache
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=500

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=30
